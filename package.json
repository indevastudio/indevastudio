{
  "name": "indeva-blog-generator",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "generate":       "node scripts/generate.js",
    "generate:force": "node scripts/generate.js --force",
    "generate:single":"node scripts/generate.js --slug",
    "validate":       "node scripts/validate.js",
    "audit":          "node scripts/generate.js --audit",
    "sitemap":        "node scripts/sitemap.js",
    "health":         "node scripts/health-check.js",
    "health:all":     "node scripts/health-check.js --all",
    "publish":        "node scripts/validate.js && node scripts/generate.js && node scripts/sitemap.js && git add insights/ sitemap.xml && git commit -m 'auto: publish blog posts' && git push"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
